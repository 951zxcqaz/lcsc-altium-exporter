<Application x:Class="Transform.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Transform.App">
    <Application.Resources>
        <ResourceDictionary>
            <Style x:Key="TitleBarStyle" TargetType="Grid">
                <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundAccentBrush}" />
                <Setter Property="Height" Value="48" />
            </Style>
            
            <Style x:Key="MainContentStyle" TargetType="Grid">
                <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeWhiteBrush}" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>