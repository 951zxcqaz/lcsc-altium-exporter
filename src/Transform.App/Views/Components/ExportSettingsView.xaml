<UserControl x:Class="Transform.App.Views.Components.ExportSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Transform.App.Views.Components"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="400">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Text="导出设置" FontSize="16" FontWeight="Bold" Margin="0,0,0,8" />

        <TextBlock Grid.Row="1" Grid.Column="0" Text="导出类型:" VerticalAlignment="Center" />
        <ComboBox Grid.Row="1" Grid.Column="1"
                  ItemsSource="{Binding ExportTypes}"
                  SelectedItem="{Binding SelectedExportType}" />

        <TextBlock Grid.Row="2" Grid.Column="0" Text="输出目录:" VerticalAlignment="Center" Margin="0,8,0,0" />
        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,8,0,0">
            <TextBox Text="{Binding OutputDirectory}"
                     Width="180"
                     Margin="0,0,8,0" />
            <Button Content="浏览..."
                    Command="{Binding BrowseOutputDirectoryCommand}" />
        </StackPanel>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="库名称:" VerticalAlignment="Center" Margin="0,8,0,0" />
        <TextBox Grid.Row="3" Grid.Column="1"
                 Text="{Binding LibraryName}"
                 Margin="0,8,0,0" />

        <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,8,0,0">
            <CheckBox Content="嵌入STEP模型" IsChecked="{Binding EmbedStepModel}" />
            <CheckBox Content="合并输出" IsChecked="{Binding MergeOutput}" />
            <CheckBox Content="追加模式" IsChecked="{Binding AppendMode}" />
        </StackPanel>

        <Button Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2"
                Content="开始导出"
                Command="{Binding ExportCommand}"
                HorizontalAlignment="Right"
                Margin="0,16,0,0" />
    </Grid>
</UserControl>
